{
  "name": "prototy",
  "version": "1.0.0",
  "description": "A simple JS framework for rapid UI prototyping on the web.",
  "main": "src/index.js",
  "scripts": {
    "dev": "vite --config vite.config.demo.js",
    "build": "npm run lint && npm run build:lib",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:demo": "vite build --config vite.config.demo.js",
    "lint": "eslint ./src -f table",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=json --outputFile=test-results.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prototyjs/prototy.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/prototyjs/prototy/issues"
  },
  "homepage": "https://github.com/prototyjs/prototy#readme",
  "devDependencies": {
    "@cspell/eslint-plugin": "^9.6.0",
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.2",
    "eslint-formatter-table": "^7.32.1",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^17.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tsc-files": "^1.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "lint-staged": {
    "src/**/*.js": [
      "eslint --no-fix --format table",
      "tsc-files --p jsconfig.json --noEmit"
    ],
    "src/**/!(*.js)": [
      "eslint --no-fix --format table"
    ]
  },
  "dependencies": {
    "vite": "^7.3.1"
  }
}
