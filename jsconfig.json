{
	"compilerOptions": {
        "types": ["vite/client"],
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
        "maxNodeModuleJsDepth": 0,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"jsx": "preserve",
		"lib": [
			"ESNext",
			"DOM"
		],
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
    ],
	"exclude": [
		"node_modules",
        "domo",
		"dist",
		"cypress"
    ]
}